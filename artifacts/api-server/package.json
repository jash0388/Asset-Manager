    "pino-http": "^10",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
